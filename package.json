{
  "name": "rpcraft",
  "version": "0.2.3",
  "description": "Type-safe RPC toolkit for client and server, built to run anywhere.",
  "homepage": "https://github.com/skordyr/rpcraft#readme",
  "license": "MIT",
  "author": "skordyr <xyan.sk@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skordyr/rpcraft.git"
  },
  "files": [
    "dist",
    "*.md"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./http-link": "./dist/http-link.mjs",
    "./log-link": "./dist/log-link.mjs",
    "./mock-link": "./dist/mock-link.mjs",
    "./rpc": "./dist/rpc.mjs",
    "./template": "./dist/template.mjs",
    "./validate-link": "./dist/validate-link.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "format": "oxfmt",
    "lint": "oxlint",
    "build": "tsdown",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0",
    "eventsource-parser": "^3.0.7"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "tsdown": "^0.21.9",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.33.0"
}
