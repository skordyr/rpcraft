{
  "name": "rpcraft",
  "version": "0.1.0",
  "description": "Type-safe RPC toolkit for client and server, built to run anywhere.",
  "homepage": "https://github.com/skordyr/rpcraft#readme",
  "license": "MIT",
  "author": "skordyr <xyan.sk@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skordyr/rpcraft.git"
  },
  "files": [
    "dist",
    "*.md"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./iterator": "./dist/iterator.mjs",
    "./links/http": "./dist/links/http/index.mjs",
    "./links/log": "./dist/links/log/index.mjs",
    "./links/mock": "./dist/links/mock/index.mjs",
    "./links/validate": "./dist/links/validate/index.mjs",
    "./rpc": "./dist/rpc.mjs",
    "./template": "./dist/template.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "format": "oxfmt",
    "lint": "oxlint",
    "build": "tsdown",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0",
    "eventsource-parser": "^3.0.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.5.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.32.1"
}
